#include <stdio.h>
 
int main() {
    
    int codigo, codigo2, qtd, qtd2;
    double valor, valor2, total;
    scanf("%d", &codigo);
    scanf("%d", &qtd);
    scanf("%lf", &valor);
    scanf("%d", &codigo2);
    scanf("%d", &qtd2);
    scanf("%lf", &valor2);
    total = ((double)qtd * valor) + ((double)qtd2 * valor2);
    printf("VALOR A PAGAR: R$ %.2lf\n",total);

}
